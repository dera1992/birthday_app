components:
  schemas:
    BirthdayEventRead:
      type: object
      properties:
        id:
          type: integer
          readOnly: true
        host:
          type: integer
        payee_user:
          type: integer
          nullable: true
        title:
          type: string
          maxLength: 255
        description:
          type: string
        agenda:
          type: string
        category:
          type: string
          maxLength: 64
        start_at:
          type: string
          format: date-time
        end_at:
          type: string
          format: date-time
        visibility:
          $ref: '#/components/schemas/VisibilityEc4Enum'
        expand_to_strangers:
          type: boolean
        location_point:
          $ref: '#/components/schemas/PointValue'
        radius_meters:
          type: integer
          maximum: 2147483647
          minimum: 0
        approx_area_label:
          type: string
          maxLength: 255
        min_guests:
          type: integer
          maximum: 2147483647
          minimum: 0
        max_guests:
          type: integer
          maximum: 2147483647
          minimum: 0
        criteria: {}
        payment_mode:
          $ref: '#/components/schemas/PaymentModeEnum'
